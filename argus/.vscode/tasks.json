{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "argus-rerank: setup (venv + install)",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev_setup.ps1",
      "windows": {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev_setup.ps1"
      },
      "linux": {
        "command": "bash scripts/dev_setup.sh"
      },
      "osx": {
        "command": "bash scripts/dev_setup.sh"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "argus-rerank: pytest",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "pytest", "-ra"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "${workspaceFolder}/.venv/Scripts/python.exe"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "argus-rerank: ruff check",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "ruff", "check", "."],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "${workspaceFolder}/.venv/Scripts/python.exe"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "argus-rerank: mypy",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["-m", "mypy", "src/argus_rerank"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "${workspaceFolder}/.venv/Scripts/python.exe"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "argus-rerank: demo (ftx_demo)",
      "type": "process",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": ["examples/ftx_demo.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "windows": {
        "command": "${workspaceFolder}/.venv/Scripts/python.exe"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
